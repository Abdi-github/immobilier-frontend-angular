{
  "name": "immobilier-frontend-angular",
  "version": "0.1.0",
  "description": "Real estate platform frontend — Angular SPA consuming immobilier-api-node",
  "author": "SwiftApp Dev Team",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:docker": "ng serve --proxy-config proxy.conf.docker.json --host 0.0.0.0",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test:watch": "ng test",
    "lint": "ng lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "dayjs": "^1.11.13",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.17",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "postcss": "^8.5.9",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  }
}
